{
  "$schema": "https://opencode.ai/config.json",
  "model": "opencode/deepseek-v4-flash-free",
  "small_model": "opencode/deepseek-v4-flash-free",
  "default_agent": "router",
  "instructions": ["instructions/ai-engineering-system.md"],
  "agent": {
    "orchestrator": {
      "mode": "subagent",
      "model": "opencode-go/minimax-m3",
      "description": "Leads multi-component non-OpenAI work: decomposes, delegates delivery/assurance/components, and synthesizes — the smart model that owns the sequence. CRITICAL: When any image data is received (clipboard, paste, upload, attachment, or image file path), IMMEDIATELY delegate to vision agent without attempting to process it yourself.",
      "steps": 35,
      "permission": {
        "edit": "deny",
        "bash": "deny",
        "external_directory": "deny",
        "webfetch": "deny",
        "websearch": "deny",
        "task": {
          "*": "deny",
          "worker": "allow",
          "worker-paid": "allow",
          "tests": "allow",
          "tests-paid": "allow",
          "lint": "allow",
          "lint-paid": "allow",
          "docs": "allow",
