          "diff-reader": "allow"
        }
      },
    },
    "minimax-reviewer": {
      "mode": "subagent",
      "model": "opencode-go/minimax-m3",
      "description": "MiniMax M3 normal-risk delivery reviewer (read-only). Reviews ordinary focused diffs — NOT gated work (that is glm-reviewer) and NOT implementation (that is minimax-code).",
      "steps": 25,
      "permission": { "edit": "deny", "bash": "deny", "task": "deny", "webfetch": "deny", "websearch": "deny" },
    },
    "glm-engineer": {
      "mode": "subagent",
      "model": "opencode-go/glm-5.2",
      "description": "GLM 5.2 planning and assurance lead (read-only). PLANS every feature/refactor/bug fix and gathers compressed evidence via cheap Flash readers. Does NOT implement (that is minimax-code) and does NOT review (that is glm-reviewer).",
      "steps": 30,
      "permission": {
        "edit": "deny",
        "bash": "deny",
        "webfetch": "deny",
        "websearch": "deny",
        "task": {
