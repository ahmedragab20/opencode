          "gpt-expert": "allow",
          "openai": "allow",
          "openai-orchestrator": "allow"
        }
      },
    },
    "worker": {
      "mode": "subagent",
      "model": "opencode/deepseek-v4-flash-free",
      "description": "Performs low-risk mechanical implementation, boilerplate, CRUD, fixtures, mocks, and simple refactors.",
      "steps": 6,
      "permission": { "task": "deny", "webfetch": "deny", "websearch": "deny" },
    },
    "worker-paid": {
      "mode": "subagent",
      "model": "opencode-go/deepseek-v4-flash",
      "description": "Paid fallback for low-risk mechanical implementation when DeepSeek V4 Flash Free is unavailable.",
      "steps": 6,
      "permission": { "task": "deny", "webfetch": "deny", "websearch": "deny" },
    },
    "minimax-code": {
      "mode": "subagent",
      "model": "opencode-go/minimax-m3",
      "description": "MiniMax M3 delivery engineer. IMPLEMENTS a GLM plan — features, refactors, bug fixes. Does NOT plan (that is glm-engineer) and does NOT review (that is minimax-reviewer / glm-reviewer).",
      "steps": 40,
      "permission": {
        "webfetch": "deny",
        "websearch": "deny",
        "task": {
          "*": "deny",
          "worker": "allow",
