{
  "$schema": "https://opencode.ai/config.json",
  "model": "openai/gpt-5.6-terra",
  "small_model": "opencode/deepseek-v4-flash-free",
  "default_agent": "orchestrator",
  "instructions": ["instructions/ai-engineering-system.md"],
  "agent": {
    "orchestrator": {
      "mode": "primary",
      "model": "opencode-go/minimax-m3",
      "description": "Routes tasks, plans work, delegates to specialists, and verifies engineering quality.",
    },
    "router": {
      "mode": "subagent",
      "model": "opencode/deepseek-v4-flash-free",
      "description": "Chooses the cheapest capable model based on risk, modality, accuracy, and context size.",
    },
    "router-paid": {
      "mode": "subagent",
      "model": "opencode-go/deepseek-v4-flash",
      "description": "Paid fallback router when DeepSeek V4 Flash Free is unavailable, rate-limited, or over quota.",
    },
    "worker": {
      "mode": "subagent",
      "model": "opencode/deepseek-v4-flash-free",
      "description": "Performs low-risk mechanical implementation, boilerplate, CRUD, fixtures, mocks, and simple refactors.",
    },
    "worker-paid": {
      "mode": "subagent",
      "model": "opencode-go/deepseek-v4-flash",
      "description": "Paid fallback for low-risk mechanical implementation when DeepSeek V4 Flash Free is unavailable.",
    },
    "minimax-code": {
      "mode": "subagent",
      "model": "opencode-go/minimax-m3",
      "description": "Delivery engineer for normal-risk coding, refactors, bug fixes, and bounded fix cycles.",
    },
    "minimax-reviewer": {
      "mode": "subagent",
      "model": "opencode-go/minimax-m3",
      "description": "Independent normal-risk reviewer for focused diffs and verification evidence; escalates assurance-gated changes to GLM.",
    },
    "glm-engineer": {
      "mode": "subagent",
      "model": "opencode-go/glm-5.2",
      "description": "Handles hard engineering, architecture, complex debugging, migrations, reviews, security, and performance.",
    },
    "reviewer": {
      "mode": "subagent",
      "model": "opencode-go/glm-5.2",
      "description": "High-assurance reviewer for risk-gated changes: security, data, public APIs, schemas, persistence, concurrency, migrations, and material ambiguity.",
    },
    "vision": {
      "mode": "subagent",
      "model": "opencode/mimo-v2.5-free",
      "description": "Parses screenshots, UI screenshots, terminal screenshots, diagrams, OCR, and code screenshots into structured markdown.",
      "permission": {
        "bash": "allow",
        "external_directory": "allow",
      },
    },
    "vision-paid": {
      "mode": "subagent",
      "model": "opencode-go/mimo-v2.5",
      "description": "Paid fallback visual parser when MiMo V2.5 Free is unavailable, rate-limited, or over quota.",
      "permission": {
        "bash": "allow",
        "external_directory": "allow",
      },
    },
    "media-expert": {
      "mode": "subagent",
      "model": "openai/gpt-5.6-terra",
      "description": "Handles complex media visioning that MiMo cannot parse accurately.",
      "permission": {
        "bash": "allow",
        "external_directory": "allow",
      },
    },
    "gpt-expert": {
      "mode": "subagent",
      "model": "openai/gpt-5.6-sol",
      "description": "Rare OpenAI GPT expert for very complicated tasks where GLM 5.2 is insufficient.",
    },
    "openai": {
      "mode": "primary",
      "model": "openai/gpt-5.6-terra",
      "description": "OpenAI-only primary: Terra delivers routine engineering, Luna handles utility work, and Sol is reserved for high-assurance judgment.",
    },
    "openai-orchestrator": {
      "mode": "subagent",
      "model": "openai/gpt-5.6-terra",
      "description": "OpenAI-only delivery orchestrator; decomposes work and routes utility work to Luna and high-assurance judgment to Sol.",
    },
    "openai-coder": {
      "mode": "subagent",
      "model": "openai/gpt-5.6-terra",
      "description": "OpenAI-only delivery engineer for bounded features, refactors, bug fixes, and integration work.",
    },
    "openai-reviewer": {
      "mode": "subagent",
      "model": "openai/gpt-5.6-terra",
      "description": "OpenAI-only routine reviewer; escalates high-assurance review to Sol.",
    },
    "openai-sol-engineer": {
      "mode": "subagent",
      "model": "openai/gpt-5.6-sol",
      "description": "OpenAI-only high-assurance lead for architecture, security, migrations, ambiguous behavior, and hard debugging.",
    },
    "openai-sol-reviewer": {
      "mode": "subagent",
      "model": "openai/gpt-5.6-sol",
      "description": "OpenAI-only final high-assurance reviewer for behavior, security, data, API, schema, and concurrency changes.",
    },
    "openai-luna-worker": {
      "mode": "subagent",
      "model": "openai/gpt-5.6-luna",
      "description": "OpenAI-only low-risk mechanical implementation, fixtures, mocks, and boilerplate specialist.",
    },
    "openai-luna-tests": {
      "mode": "subagent",
      "model": "openai/gpt-5.6-luna",
      "description": "OpenAI-only specialist for clear test updates, fixtures, mocks, snapshots, and focused test execution.",
    },
    "openai-luna-docs": {
      "mode": "subagent",
      "model": "openai/gpt-5.6-luna",
      "description": "OpenAI-only documentation, comments, changelog, and README specialist.",
    },
    "openai-luna-git": {
      "mode": "subagent",
      "model": "openai/gpt-5.6-luna",
      "description": "OpenAI-only git-status, commit-message, PR-summary, and release-note specialist.",
    },
    "openai-luna-lint": {
      "mode": "subagent",
      "model": "openai/gpt-5.6-luna",
      "description": "OpenAI-only formatting, import cleanup, lint-only, and style-only specialist.",
    },
    "openai-luna-reader": {
      "mode": "subagent",
      "model": "openai/gpt-5.6-luna",
      "description": "OpenAI-only compressor for terminal output, logs, test failures, and large diffs.",
    },
    "openai-media-expert": {
      "mode": "subagent",
      "model": "openai/gpt-5.6-terra",
      "description": "OpenAI-only media, screenshot, OCR, UI, and multimodal reasoning specialist.",
    },
    "terminal-reader": {
      "mode": "subagent",
      "model": "opencode/deepseek-v4-flash-free",
      "description": "Compresses large terminal output into errors, warnings, first failure, likely root cause, and relevant files.",
    },
    "terminal-reader-paid": {
      "mode": "subagent",
      "model": "opencode-go/deepseek-v4-flash",
      "description": "Paid fallback terminal-output compressor when DeepSeek V4 Flash Free is unavailable.",
    },
    "log-reader": {
      "mode": "subagent",
      "model": "opencode/deepseek-v4-flash-free",
      "description": "Compresses logs into repeated exceptions, timestamps, frequencies, and likely failing subsystem.",
    },
    "log-reader-paid": {
      "mode": "subagent",
      "model": "opencode-go/deepseek-v4-flash",
      "description": "Paid fallback log compressor when DeepSeek V4 Flash Free is unavailable.",
    },
    "diff-reader": {
      "mode": "subagent",
      "model": "opencode/deepseek-v4-flash-free",
      "description": "Compresses large git diffs into changed APIs, risky files, behavior changes, and migration notes.",
    },
    "diff-reader-paid": {
      "mode": "subagent",
      "model": "opencode-go/deepseek-v4-flash",
      "description": "Paid fallback diff compressor when DeepSeek V4 Flash Free is unavailable.",
    },
    "git": {
      "mode": "subagent",
      "model": "opencode/deepseek-v4-flash-free",
      "description": "Writes commit messages, release notes, PR summaries, and git change summaries.",
    },
    "git-paid": {
      "mode": "subagent",
      "model": "opencode-go/deepseek-v4-flash",
      "description": "Paid fallback git communication specialist when DeepSeek V4 Flash Free is unavailable.",
    },
    "docs": {
      "mode": "subagent",
      "model": "opencode/deepseek-v4-flash-free",
      "description": "Writes README content, markdown docs, comments, and documentation updates.",
    },
    "docs-paid": {
      "mode": "subagent",
      "model": "opencode-go/deepseek-v4-flash",
      "description": "Paid fallback documentation specialist when DeepSeek V4 Flash Free is unavailable.",
    },
    "lint": {
      "mode": "subagent",
      "model": "opencode/deepseek-v4-flash-free",
      "description": "Handles formatting, lint, imports, and style without intentional runtime behavior changes.",
    },
    "lint-paid": {
      "mode": "subagent",
      "model": "opencode-go/deepseek-v4-flash",
      "description": "Paid fallback lint and formatting specialist when DeepSeek V4 Flash Free is unavailable.",
    },
    "tests": {
      "mode": "subagent",
      "model": "opencode/deepseek-v4-flash-free",
      "description": "Writes and updates tests, integration tests, snapshots, fixtures, and mocks.",
    },
    "tests-paid": {
      "mode": "subagent",
      "model": "opencode-go/deepseek-v4-flash",
      "description": "Paid fallback tests specialist when DeepSeek V4 Flash Free is unavailable.",
    },
    "memory": {
      "mode": "subagent",
      "model": "opencode/deepseek-v4-flash-free",
      "description": "Maintains rolling repository memory and refreshes project summaries after significant changes.",
    },
    "memory-paid": {
      "mode": "subagent",
      "model": "opencode-go/deepseek-v4-flash",
      "description": "Paid fallback repository memory maintainer when DeepSeek V4 Flash Free is unavailable.",
    },
  },
}
