{
  "$schema": "https://opencode.ai/config.json",
  "model": "opencode-go/minimax-m3",
  "small_model": "opencode-go/minimax-m3",
  "default_agent": "router",
  "instructions": ["instructions/ai-engineering-system.md"],
  "provider": {
    "opencode-go": {
      "models": {
        "minimax-m3": {
          "id": "opencode-go/minimax-m3",
          "attachment": true,
          "modalities": {
            "input": ["text", "image"],
            "output": ["text"]
          }
        }
      }
    }
  },
  "agent": {
    "orchestrator": {
      "mode": "subagent",
      "model": "opencode-go/minimax-m3",
      "description": "Coordinates only multi-component non-OpenAI work after routing; delegates delivery and assurance decisions.",
      "steps": 8,
      "permission": {
        "edit": "deny",
        "bash": "deny",
        "external_directory": "deny",
        "webfetch": "deny",
        "websearch": "deny",
        "task": {
          "*": "deny",
          "worker": "allow",
          "worker-paid": "allow",
          "tests": "allow",
          "tests-paid": "allow",
          "lint": "allow",
          "lint-paid": "allow",
          "docs": "allow",
          "docs-paid": "allow",
          "git": "allow",
          "git-paid": "allow",
          "memory": "allow",
          "memory-paid": "allow",
          "terminal-reader": "allow",
          "terminal-reader-paid": "allow",
          "log-reader": "allow",
          "log-reader-paid": "allow",
          "diff-reader": "allow",
          "diff-reader-paid": "allow",
          "minimax-code": "allow",
          "minimax-reviewer": "allow",
          "glm-engineer": "allow",
          "reviewer": "allow",
          "vision": "allow",
          "vision-paid": "allow",
          "media-expert": "allow",
          "gpt-expert": "allow"
        }
      },
    },
    "router": {
      "mode": "primary",
      "model": "opencode-go/minimax-m3",
      "description": "Cheap first hop that answers trivial read-only requests and routes bounded work to the cheapest capable lane.",
      "steps": 8,
      "permission": {
        "edit": "deny",
        "bash": "deny",
        "external_directory": "deny",
        "webfetch": "deny",
        "websearch": "deny",
        "task": {
          "*": "deny",
          "orchestrator": "allow",
          "worker": "allow",
          "worker-paid": "allow",
          "tests": "allow",
          "tests-paid": "allow",
          "lint": "allow",
          "lint-paid": "allow",
          "docs": "allow",
          "docs-paid": "allow",
          "git": "allow",
          "git-paid": "allow",
          "memory": "allow",
          "memory-paid": "allow",
          "terminal-reader": "allow",
          "terminal-reader-paid": "allow",
          "log-reader": "allow",
          "log-reader-paid": "allow",
          "diff-reader": "allow",
          "diff-reader-paid": "allow",
          "minimax-code": "allow",
          "minimax-reviewer": "allow",
          "glm-engineer": "allow",
          "reviewer": "allow",
          "vision": "allow",
          "vision-paid": "allow",
          "media-expert": "allow",
          "gpt-expert": "allow",
          "openai": "allow",
          "openai-orchestrator": "allow"
        }
      },
    },
    "router-paid": {
      "mode": "all",
      "model": "opencode-go/deepseek-v4-flash",
      "description": "Paid fallback router when DeepSeek V4 Flash Free is unavailable, rate-limited, or over quota.",
      "steps": 8,
      "permission": {
        "edit": "deny",
        "bash": "deny",
        "external_directory": "deny",
        "webfetch": "deny",
        "websearch": "deny",
        "task": {
          "*": "deny",
          "orchestrator": "allow",
          "worker": "allow",
          "worker-paid": "allow",
          "tests": "allow",
          "tests-paid": "allow",
          "lint": "allow",
          "lint-paid": "allow",
          "docs": "allow",
          "docs-paid": "allow",
          "git": "allow",
          "git-paid": "allow",
          "memory": "allow",
          "memory-paid": "allow",
          "terminal-reader": "allow",
          "terminal-reader-paid": "allow",
          "log-reader": "allow",
          "log-reader-paid": "allow",
          "diff-reader": "allow",
          "diff-reader-paid": "allow",
          "minimax-code": "allow",
          "minimax-reviewer": "allow",
          "glm-engineer": "allow",
          "reviewer": "allow",
          "vision": "allow",
          "vision-paid": "allow",
          "media-expert": "allow",
          "gpt-expert": "allow",
          "openai": "allow",
          "openai-orchestrator": "allow"
        }
      },
    },
    "worker": {
      "mode": "subagent",
      "model": "opencode/deepseek-v4-flash-free",
      "description": "Performs low-risk mechanical implementation, boilerplate, CRUD, fixtures, mocks, and simple refactors.",
      "steps": 6,
      "permission": { "task": "deny", "webfetch": "deny", "websearch": "deny" },
    },
    "worker-paid": {
      "mode": "subagent",
      "model": "opencode-go/deepseek-v4-flash",
      "description": "Paid fallback for low-risk mechanical implementation when DeepSeek V4 Flash Free is unavailable.",
      "steps": 6,
      "permission": { "task": "deny", "webfetch": "deny", "websearch": "deny" },
    },
    "minimax-code": {
      "mode": "subagent",
      "model": "opencode-go/minimax-m3",
      "description": "Delivery engineer for normal-risk coding, refactors, bug fixes, and bounded fix cycles.",
      "steps": 12,
      "permission": {
        "webfetch": "deny",
        "websearch": "deny",
        "task": {
          "*": "deny",
          "worker": "allow",
          "tests": "allow",
          "lint": "allow",
          "docs": "allow",
          "git": "allow",
          "terminal-reader": "allow",
          "log-reader": "allow",
          "diff-reader": "allow"
        }
      },
    },
    "minimax-reviewer": {
      "mode": "subagent",
      "model": "opencode-go/minimax-m3",
      "description": "Read-only routine reviewer that returns findings or an assurance-gate handoff to its parent.",
      "steps": 6,
      "permission": { "edit": "deny", "bash": "deny", "task": "deny", "webfetch": "deny", "websearch": "deny" },
    },
    "glm-engineer": {
      "mode": "subagent",
      "model": "opencode-go/glm-5.2",
      "description": "Read-only GLM assurance decision agent that returns bounded specifications and expert-consult handoffs.",
      "steps": 6,
      "permission": { "edit": "deny", "bash": "deny", "task": "deny", "webfetch": "deny", "websearch": "deny" },
    },
    "reviewer": {
      "mode": "subagent",
      "model": "opencode-go/glm-5.2",
      "description": "High-assurance reviewer for risk-gated changes: security, data, public APIs, schemas, persistence, concurrency, migrations, and material ambiguity.",
      "steps": 6,
      "permission": { "edit": "deny", "bash": "deny", "task": "deny", "webfetch": "deny", "websearch": "deny" },
    },
    "vision": {
      "mode": "subagent",
      "model": "opencode/mimo-v2.5-free",
      "description": "Parses screenshots, UI screenshots, terminal screenshots, diagrams, OCR, and code screenshots into structured markdown.",
      "steps": 6,
      "permission": {
        "bash": "allow",
        "external_directory": "allow",
        "edit": "deny",
        "task": "deny",
        "webfetch": "deny",
        "websearch": "deny",
      },
    },
    "vision-paid": {
      "mode": "subagent",
      "model": "opencode-go/mimo-v2.5",
      "description": "Paid fallback visual parser when MiMo V2.5 Free is unavailable, rate-limited, or over quota.",
      "steps": 6,
      "permission": {
        "bash": "allow",
        "external_directory": "allow",
        "edit": "deny",
        "task": "deny",
        "webfetch": "deny",
        "websearch": "deny",
      },
    },
    "media-expert": {
      "mode": "subagent",
      "model": "openai/gpt-5.6-terra",
      "description": "Handles complex media visioning that MiMo cannot parse accurately.",
      "steps": 6,
      "permission": {
        "bash": "allow",
        "external_directory": "allow",
        "edit": "deny",
        "task": "deny",
        "webfetch": "deny",
        "websearch": "deny",
      },
    },
    "gpt-expert": {
      "mode": "subagent",
      "model": "openai/gpt-5.6-sol",
      "description": "Rare OpenAI GPT expert for very complicated tasks where GLM 5.2 is insufficient.",
      "steps": 6,
      "permission": { "edit": "deny", "bash": "deny", "task": "deny", "webfetch": "deny", "websearch": "deny" },
    },
    "openai": {
      "mode": "all",
      "model": "openai/gpt-5.6-luna",
      "description": "OpenAI-only cheap first hop: Luna answers trivial read-only work and routes Terra delivery or explicitly gated Sol decisions.",
      "steps": 8,
      "permission": {
        "edit": "deny",
        "bash": "deny",
        "external_directory": "deny",
        "webfetch": "deny",
        "websearch": "deny",
        "task": {
          "*": "deny",
          "openai-orchestrator": "allow",
          "openai-coder": "allow",
          "openai-reviewer": "allow",
          "openai-sol-engineer": "allow",
          "openai-sol-reviewer": "allow",
          "openai-luna-worker": "allow",
          "openai-luna-tests": "allow",
          "openai-luna-docs": "allow",
          "openai-luna-git": "allow",
          "openai-luna-lint": "allow",
          "openai-luna-reader": "allow",
          "openai-media-expert": "allow"
        }
      },
    },
    "openai-orchestrator": {
      "mode": "all",
      "model": "openai/gpt-5.6-terra",
      "description": "OpenAI-only delivery orchestrator; decomposes work and routes utility work to Luna and high-assurance judgment to Sol.",
      "steps": 8,
      "permission": {
        "edit": "deny",
        "bash": "deny",
        "external_directory": "deny",
        "webfetch": "deny",
        "websearch": "deny",
        "task": {
          "*": "deny",
          "openai-coder": "allow",
          "openai-reviewer": "allow",
          "openai-sol-engineer": "allow",
          "openai-sol-reviewer": "allow",
          "openai-luna-worker": "allow",
          "openai-luna-tests": "allow",
          "openai-luna-docs": "allow",
          "openai-luna-git": "allow",
          "openai-luna-lint": "allow",
          "openai-luna-reader": "allow",
          "openai-media-expert": "allow"
        }
      },
    },
    "openai-coder": {
      "mode": "subagent",
      "model": "openai/gpt-5.6-terra",
      "description": "OpenAI-only delivery engineer for bounded features, refactors, bug fixes, and integration work.",
      "steps": 12,
      "permission": {
        "webfetch": "deny",
        "websearch": "deny",
        "task": {
          "*": "deny",
          "openai-luna-worker": "allow",
          "openai-luna-tests": "allow",
          "openai-luna-docs": "allow",
          "openai-luna-git": "allow",
          "openai-luna-lint": "allow",
          "openai-luna-reader": "allow"
        }
      },
    },
    "openai-reviewer": {
      "mode": "subagent",
      "model": "openai/gpt-5.6-terra",
      "description": "OpenAI-only read-only routine reviewer that returns findings or an assurance-gate handoff.",
      "steps": 6,
      "permission": { "edit": "deny", "bash": "deny", "task": "deny", "webfetch": "deny", "websearch": "deny" },
    },
    "openai-sol-engineer": {
      "mode": "subagent",
      "model": "openai/gpt-5.6-sol",
      "description": "OpenAI-only high-assurance lead for architecture, security, migrations, ambiguous behavior, and hard debugging.",
      "steps": 6,
      "permission": { "edit": "deny", "bash": "deny", "task": "deny", "webfetch": "deny", "websearch": "deny" },
    },
    "openai-sol-reviewer": {
      "mode": "subagent",
      "model": "openai/gpt-5.6-sol",
      "description": "OpenAI-only final high-assurance reviewer for behavior, security, data, API, schema, and concurrency changes.",
      "steps": 6,
      "permission": { "edit": "deny", "bash": "deny", "task": "deny", "webfetch": "deny", "websearch": "deny" },
    },
    "openai-luna-worker": {
      "mode": "subagent",
      "model": "openai/gpt-5.6-luna",
      "description": "OpenAI-only low-risk mechanical implementation, fixtures, mocks, and boilerplate specialist.",
      "steps": 6,
      "permission": { "task": "deny", "webfetch": "deny", "websearch": "deny" },
    },
    "openai-luna-tests": {
      "mode": "subagent",
      "model": "openai/gpt-5.6-luna",
      "description": "OpenAI-only specialist for clear test updates, fixtures, mocks, snapshots, and focused test execution.",
      "steps": 6,
      "permission": { "task": "deny", "webfetch": "deny", "websearch": "deny" },
    },
    "openai-luna-docs": {
      "mode": "subagent",
      "model": "openai/gpt-5.6-luna",
      "description": "OpenAI-only documentation, comments, changelog, and README specialist.",
      "steps": 6,
      "permission": { "task": "deny", "webfetch": "deny", "websearch": "deny" },
    },
    "openai-luna-git": {
      "mode": "subagent",
      "model": "openai/gpt-5.6-luna",
      "description": "OpenAI-only git-status, commit-message, PR-summary, and release-note specialist.",
      "steps": 4,
      "permission": { "edit": "deny", "task": "deny", "webfetch": "deny", "websearch": "deny" },
    },
    "openai-luna-lint": {
      "mode": "subagent",
      "model": "openai/gpt-5.6-luna",
      "description": "OpenAI-only formatting, import cleanup, lint-only, and style-only specialist.",
      "steps": 6,
      "permission": { "task": "deny", "webfetch": "deny", "websearch": "deny" },
    },
    "openai-luna-reader": {
      "mode": "subagent",
      "model": "openai/gpt-5.6-luna",
      "description": "OpenAI-only compressor for terminal output, logs, test failures, and large diffs.",
      "steps": 4,
      "permission": { "edit": "deny", "task": "deny", "webfetch": "deny", "websearch": "deny" },
    },
    "openai-media-expert": {
      "mode": "subagent",
      "model": "openai/gpt-5.6-terra",
      "description": "OpenAI-only media, screenshot, OCR, UI, and multimodal reasoning specialist.",
      "steps": 6,
      "permission": { "edit": "deny", "task": "deny", "webfetch": "deny", "websearch": "deny" },
    },
    "terminal-reader": {
      "mode": "subagent",
      "model": "opencode/deepseek-v4-flash-free",
      "description": "Compresses large terminal output into errors, warnings, first failure, likely root cause, and relevant files.",
      "steps": 4,
      "permission": { "edit": "deny", "task": "deny", "webfetch": "deny", "websearch": "deny" },
    },
    "terminal-reader-paid": {
      "mode": "subagent",
      "model": "opencode-go/deepseek-v4-flash",
      "description": "Paid fallback terminal-output compressor when DeepSeek V4 Flash Free is unavailable.",
      "steps": 4,
      "permission": { "edit": "deny", "task": "deny", "webfetch": "deny", "websearch": "deny" },
    },
    "log-reader": {
      "mode": "subagent",
      "model": "opencode/deepseek-v4-flash-free",
      "description": "Compresses logs into repeated exceptions, timestamps, frequencies, and likely failing subsystem.",
      "steps": 4,
      "permission": { "edit": "deny", "task": "deny", "webfetch": "deny", "websearch": "deny" },
    },
    "log-reader-paid": {
      "mode": "subagent",
      "model": "opencode-go/deepseek-v4-flash",
      "description": "Paid fallback log compressor when DeepSeek V4 Flash Free is unavailable.",
      "steps": 4,
      "permission": { "edit": "deny", "task": "deny", "webfetch": "deny", "websearch": "deny" },
    },
    "diff-reader": {
      "mode": "subagent",
      "model": "opencode/deepseek-v4-flash-free",
      "description": "Compresses large git diffs into changed APIs, risky files, behavior changes, and migration notes.",
      "steps": 4,
      "permission": { "edit": "deny", "task": "deny", "webfetch": "deny", "websearch": "deny" },
    },
    "diff-reader-paid": {
      "mode": "subagent",
      "model": "opencode-go/deepseek-v4-flash",
      "description": "Paid fallback diff compressor when DeepSeek V4 Flash Free is unavailable.",
      "steps": 4,
      "permission": { "edit": "deny", "task": "deny", "webfetch": "deny", "websearch": "deny" },
    },
    "git": {
      "mode": "subagent",
      "model": "opencode/deepseek-v4-flash-free",
      "description": "Writes commit messages, release notes, PR summaries, and git change summaries.",
      "steps": 4,
      "permission": { "edit": "deny", "task": "deny", "webfetch": "deny", "websearch": "deny" },
    },
    "git-paid": {
      "mode": "subagent",
      "model": "opencode-go/deepseek-v4-flash",
      "description": "Paid fallback git communication specialist when DeepSeek V4 Flash Free is unavailable.",
      "steps": 4,
      "permission": { "edit": "deny", "task": "deny", "webfetch": "deny", "websearch": "deny" },
    },
    "docs": {
      "mode": "subagent",
      "model": "opencode/deepseek-v4-flash-free",
      "description": "Writes README content, markdown docs, comments, and documentation updates.",
      "steps": 6,
      "permission": { "task": "deny", "webfetch": "deny", "websearch": "deny" },
    },
    "docs-paid": {
      "mode": "subagent",
      "model": "opencode-go/deepseek-v4-flash",
      "description": "Paid fallback documentation specialist when DeepSeek V4 Flash Free is unavailable.",
      "steps": 6,
      "permission": { "task": "deny", "webfetch": "deny", "websearch": "deny" },
    },
    "lint": {
      "mode": "subagent",
      "model": "opencode/deepseek-v4-flash-free",
      "description": "Handles formatting, lint, imports, and style without intentional runtime behavior changes.",
      "steps": 6,
      "permission": { "task": "deny", "webfetch": "deny", "websearch": "deny" },
    },
    "lint-paid": {
      "mode": "subagent",
      "model": "opencode-go/deepseek-v4-flash",
      "description": "Paid fallback lint and formatting specialist when DeepSeek V4 Flash Free is unavailable.",
      "steps": 6,
      "permission": { "task": "deny", "webfetch": "deny", "websearch": "deny" },
    },
    "tests": {
      "mode": "subagent",
      "model": "opencode/deepseek-v4-flash-free",
      "description": "Writes and updates tests, integration tests, snapshots, fixtures, and mocks.",
      "steps": 6,
      "permission": { "task": "deny", "webfetch": "deny", "websearch": "deny" },
    },
    "tests-paid": {
      "mode": "subagent",
      "model": "opencode-go/deepseek-v4-flash",
      "description": "Paid fallback tests specialist when DeepSeek V4 Flash Free is unavailable.",
      "steps": 6,
      "permission": { "task": "deny", "webfetch": "deny", "websearch": "deny" },
    },
    "memory": {
      "mode": "subagent",
      "model": "opencode/deepseek-v4-flash-free",
      "description": "Maintains rolling repository memory and refreshes project summaries after significant changes.",
      "steps": 6,
      "permission": { "task": "deny", "webfetch": "deny", "websearch": "deny" },
    },
    "memory-paid": {
      "mode": "subagent",
      "model": "opencode-go/deepseek-v4-flash",
      "description": "Paid fallback repository memory maintainer when DeepSeek V4 Flash Free is unavailable.",
      "steps": 6,
