          "glm-reviewer": "allow",
          "vision": "allow",
          "vision-paid": "allow",
          "media-expert": "allow",
          "gpt-expert": "allow"
        }
      },
    },
    "router": {
      "mode": "primary",
      "model": "opencode/deepseek-v4-flash-free",
      "description": "Cheap first-hop classifier and relay: answers trivial read-only requests, classifies the first hop, and relays smart-agent handoffs — never plans or sequences. CRITICAL: When any image data is received (clipboard, paste, upload, attachment, or image file path), IMMEDIATELY delegate to vision agent without attempting to process it yourself.",
      "steps": 30,
      "permission": {
        "edit": "deny",
        "bash": "deny",
        "todowrite": "deny",
        "external_directory": "deny",
        "webfetch": "deny",
        "websearch": "deny",
        "task": {
          "*": "deny",
          "orchestrator": "allow",
          "worker": "allow",
          "worker-paid": "allow",
