      },
    },
    "router-paid": {
      "mode": "all",
      "model": "opencode-go/deepseek-v4-flash",
      "description": "Paid fallback classifier-relay when DeepSeek V4 Flash Free is unavailable, rate-limited, or over quota. CRITICAL: When any image data is received (clipboard, paste, upload, attachment, or image file path), IMMEDIATELY delegate to vision agent without attempting to process it yourself.",
      "steps": 30,
      "permission": {
        "edit": "deny",
        "bash": "deny",
        "external_directory": "deny",
