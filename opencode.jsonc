    },
    "glm-reviewer": {
      "mode": "subagent",
      "model": "opencode-go/glm-5.2",
      "description": "GLM 5.2 gated assurance reviewer (read-only). Reviews ONLY explicitly gated results — security, data, public APIs, schemas, persistence, concurrency, migrations, material ambiguity. NOT a coder and NOT the normal-risk reviewer (that is minimax-reviewer).",
      "steps": 25,
      "permission": { "edit": "deny", "bash": "deny", "task": "deny", "webfetch": "deny", "websearch": "deny" },
    },
    "vision": {
